# NeuraRoute engine/agent config. Copy to `.env` and edit; scripts/dev_up.sh loads it.
# (This .example is committed; your real `.env` is gitignored — never commit keys.)

# --- broker (the laptop hub's IP; localhost when everything is on one machine) ---
NEURAROUTE_BROKER=localhost

# --- which model backends the tiers use ---
#   dev   = all local/mock (mock_llm + canned cloud); runs on one laptop, no real models
#   venue = REAL models everywhere: cloud->Groq, laptop->GenieX, phone->llama.cpp,
#           arduino->llama.cpp. Only the Arduino's sensor READINGS are injected (curl/app).
#
# >>> TO GO FULLY REAL: set this to `venue`, fill GROQ_API_KEY below, point the *_LLM_URL /
#     LOCAL_BASE_URL vars at the real llama.cpp servers, run ./scripts/infer_up.sh alongside
#     ./scripts/dev_up.sh, and follow "GO FULLY REAL" in docs/runbook-surface.md.
#     Flip back to `dev` (one line) for the bulletproof mock fallback. <<<
NEURAROUTE_REGISTRY=dev

# --- venue mode: where the /infer servers live -------------------------------
# laptop.py (GenieX/Qwen) -> :8000, cloud.py (Groq/Llama-70B) -> :8001,
# phone.py (llama.cpp) -> :8002. Point at each device's IP if they're on different hosts.
# scripts/infer_up.sh starts all three locally.
NEURAROUTE_INFER_LAPTOP_URL=http://localhost:8000/infer
NEURAROUTE_INFER_CLOUD_URL=http://localhost:8001/infer
NEURAROUTE_INFER_PHONE_URL=http://localhost:8002/infer

# --- cloud tier: Groq API key (servers/cloud_server.py). Without it the cloud tier
#     fails over cleanly down the ladder — the server still boots. Get one at console.groq.com.
GROQ_API_KEY=

# --- phone /infer server: the on-device model it bridges to (OpenAI-compatible llama.cpp) ---
# Real phone tier: point at the phone's llama.cpp (Termux) — its IP if phone_server runs on the Surface.
# NEURAROUTE_PHONE_LLM_URL=http://<phone-ip>:1234/v1
# NEURAROUTE_PHONE_MODEL=Qwen3-1.7B

# --- arduino tier (and phone in dev mode) — an OpenAI-compatible server (llm_client path) ---
# Real arduino SLM: point at the UNO Q's llama.cpp (a ~0.5B Q4 fits 4GB). NOTE: a real llama.cpp
# here makes arduino-01 a REAL tier via the local path — you do NOT need models/arduino.py for this.
# Leave unset in DEV mode and dev_up starts tools/mock_llm.py on :1234 for you.
# NEURAROUTE_LOCAL_BASE_URL=http://<unoq-ip>:1234/v1

# --- engine HTTP/WS port (phone app connects here). 8000/8001 belong to /infer. ---
NEURAROUTE_PORT=8080
