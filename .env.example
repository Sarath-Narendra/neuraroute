# NeuraRoute engine/agent config. Copy to `.env` and edit; scripts/dev_up.sh loads it.
# (This .example is committed; your real `.env` is gitignored — never commit keys.)

# --- broker (the laptop hub's IP; localhost when everything is on one machine) ---
NEURAROUTE_BROKER=localhost

# --- which model backends the tiers use ---
#   dev   = all local/mock (mock_llm + canned cloud); runs on one laptop, no real models
#   venue = laptop+cloud call the real /infer servers (Eswar's inference module)
NEURAROUTE_REGISTRY=dev

# --- venue mode: where the /infer servers live -------------------------------
# laptop.py (GenieX/Qwen) defaults to :8000, cloud.py (Groq/Llama-70B) to :8001.
# Point at the Surface's IP if the engine runs on a different machine.
NEURAROUTE_INFER_LAPTOP_URL=http://localhost:8000/infer
NEURAROUTE_INFER_CLOUD_URL=http://localhost:8001/infer

# --- local tiers (phone/arduino) — an OpenAI-compatible server (LM Studio / llama.cpp) ---
# Leave unset in dev mode and dev_up starts tools/mock_llm.py on :1234 for you.
# NEURAROUTE_LOCAL_BASE_URL=http://localhost:1234/v1

# --- engine HTTP/WS port (phone app connects here). 8000/8001 belong to /infer. ---
NEURAROUTE_PORT=8080
